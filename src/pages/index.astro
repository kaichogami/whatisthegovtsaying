---
import Base from "../layouts/Base.astro";
import DateNavigation from "../components/DateNavigation.astro";
import CountrySection from "../components/CountrySection.astro";
import ActionBar from "../components/ActionBar.astro";
import InlineNewsletter from "../components/InlineNewsletter.astro";
import { getLatestDigest, getAllDigestDates, getAllWeeklyDates } from "../lib/digest";
import { formatDate } from "../lib/constants";
import { md, stripMd } from "../lib/md";

const page = getLatestDigest();
const allDates = getAllDigestDates();
const weeklyDates = getAllWeeklyDates();

if (!page) {
  return Astro.redirect("/404");
}

const title = `What Is The Govt Saying — ${formatDate(page.digest.date)}`;
const description = page.digest.global_summary.replace(/[*_#>\[\]]/g, "").slice(0, 160);
const globalHtml = md(page.digest.global_summary);

const insertAfter = Math.min(5, Math.floor(page.countries.length / 2));
const countriesBefore = page.countries.slice(0, insertAfter);
const countriesAfter = page.countries.slice(insertAfter);
---

<Base title={title} description={description} date={page.digest.date} ogImage={`/og/daily/${page.digest.date}.png`} type="article">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-4 sm:py-6">
    <DateNavigation date={page.digest.date} availableDates={allDates} />

    <div class="flex items-center gap-4 mb-6 sm:mb-8 font-ui text-sm">
      <span class="font-medium text-(--color-ink) border-b-2 border-(--color-accent-1) pb-1">Daily</span>
      {weeklyDates.length > 0 ? (
        <a href={`/weekly/${weeklyDates[0]}/`} class="text-(--color-ink-muted) hover:text-(--color-accent-1) no-underline pb-1 transition-colors">
          Weekly
        </a>
      ) : (
        <span class="text-(--color-ink-muted) opacity-50 pb-1">Weekly</span>
      )}
    </div>

    <section class="mb-10 sm:mb-14">
      <div class="flex items-start justify-between gap-4 mb-4 sm:mb-5">
        <h2 class="font-headline text-xl sm:text-2xl md:text-[1.75rem] font-medium">
          {stripMd(page.digest.global_title || "What the World Governments Are Saying")}
        </h2>
        <ActionBar title={title} description={description} />
      </div>
      <div class="prose" set:html={globalHtml} />
    </section>

    <div>
      {countriesBefore.map((country) => (
        <CountrySection country={country} />
      ))}
    </div>

    <InlineNewsletter />

    <div>
      {countriesAfter.map((country) => (
        <CountrySection country={country} />
      ))}
    </div>
  </div>
</Base>
