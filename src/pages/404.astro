---
import Base from "../layouts/Base.astro";
---

<Base title="Not Found — What Is The Govt Saying" description="Page not found.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <h1 class="font-headline text-3xl font-medium mb-4">
      Not Found
    </h1>
    <p class="mb-6">No digest available for this date.</p>
    <a href="/" class="font-ui text-sm text-(--color-ink-muted) hover:text-(--color-accent-1) no-underline transition-colors">
      &larr; Back to latest digest
    </a>
  </div>
</Base>
