---
import Base from "../../layouts/Base.astro";
import ActionBar from "../../components/ActionBar.astro";
import InlineNewsletter from "../../components/InlineNewsletter.astro";
import { getWeeklyDigest, getAllWeeklyDates } from "../../lib/digest";
import { COUNTRY_FLAGS, formatDate, formatDateShort } from "../../lib/constants";
import { md, stripMd } from "../../lib/md";

export function getStaticPaths() {
  const dates = getAllWeeklyDates();
  return dates.map((date) => ({ params: { date } }));
}

const { date } = Astro.params;
const page = getWeeklyDigest(date!);
const allWeekly = getAllWeeklyDates();

if (!page) {
  return Astro.redirect("/404");
}

const idx = allWeekly.indexOf(date!);
const prevWeek = idx < allWeekly.length - 1 ? allWeekly[idx + 1] : null;
const nextWeek = idx > 0 ? allWeekly[idx - 1] : null;

// Use UTC date to match how the backend generates dates
const today = new Date().toISOString().split('T')[0];
const isCurrentWeek = page.digest.week_end >= today;

const title = `Week of ${formatDateShort(page.digest.week_start)} — ${formatDateShort(page.digest.week_end)} | What Is The Govt Saying`;
const description = page.digest.global_summary.replace(/[*_#>\[\]|]/g, "").slice(0, 160);
const globalHtml = md(page.digest.global_summary);

const insertAfter = Math.min(5, Math.floor(page.countries.length / 2));
const countriesBefore = page.countries.slice(0, insertAfter);
const countriesAfter = page.countries.slice(insertAfter);
---

<Base title={title} description={description} date={page.digest.week_end} ogImage={`/og/weekly/${date}.png`} type="article">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-4 sm:py-6">
    <nav class="flex items-center gap-3 sm:gap-5 py-3 sm:py-4 font-ui" aria-label="Weekly navigation">
      {prevWeek ? (
        <a href={`/weekly/${prevWeek}/`} class="text-sm text-(--color-ink-muted) hover:text-(--color-accent-1) no-underline transition-colors">
          &larr; Prev
        </a>
      ) : (
        <span class="text-sm text-(--color-ink-muted) opacity-40">&larr;</span>
      )}

      <span class="font-headline text-base sm:text-lg font-medium text-(--color-ink)">
        {formatDateShort(page.digest.week_start)} — {formatDate(page.digest.week_end)}
      </span>

      {nextWeek ? (
        <a href={`/weekly/${nextWeek}/`} class="text-sm text-(--color-ink-muted) hover:text-(--color-accent-1) no-underline transition-colors">
          Next &rarr;
        </a>
      ) : (
        <span class="text-sm text-(--color-ink-muted) opacity-40">&rarr;</span>
      )}
    </nav>

    <div class="flex items-center gap-4 mb-6 sm:mb-8 font-ui text-sm">
      <a href="/" class="text-(--color-ink-muted) hover:text-(--color-accent-1) no-underline pb-1 transition-colors">Daily</a>
      <span class="font-medium text-(--color-ink) border-b-2 border-(--color-accent-1) pb-1">Weekly</span>
    </div>

    {isCurrentWeek && (
      <div class="mb-6 sm:mb-8 flex items-center gap-2">
        <span class="relative flex h-2 w-2 items-center justify-center">
          <span class="animate-pulse absolute inline-flex h-2 w-2 rounded-full bg-(--color-accent-2) opacity-40" style="animation-duration: 3s;"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-(--color-accent-2)"></span>
        </span>
        <p class="font-ui text-sm text-(--color-ink-muted) m-0">
          This weekly edition is actively being updated.
        </p>
      </div>
    )}

    <section class="mb-10 sm:mb-14">
      <div class="flex items-start justify-between gap-4 mb-4 sm:mb-5">
        <h2 class="font-headline text-xl sm:text-2xl md:text-[1.75rem] font-medium">
          {stripMd(page.digest.global_title)}
        </h2>
        <ActionBar title={title} description={description} />
      </div>
      <div class="prose" set:html={globalHtml} />
    </section>

    <div>
      {countriesBefore.map((country) => {
        const flag = COUNTRY_FLAGS[country.country_code] || "";
        return (
          <article class="py-6 sm:py-8 border-t border-(--color-line)">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-base" aria-hidden="true">{flag}</span>
              <span class="font-ui text-xs font-medium uppercase tracking-widest text-(--color-ink-muted) opacity-70">
                {country.country_name}
              </span>
            </div>
            {country.title && (
              <h3 class="font-headline text-lg sm:text-xl font-medium mb-2.5">
                {stripMd(country.title)}
              </h3>
            )}
            <div class="prose text-[0.9375rem]" set:html={md(country.summary)} />
          </article>
        );
      })}
    </div>

    <InlineNewsletter />

    <div>
      {countriesAfter.map((country) => {
        const flag = COUNTRY_FLAGS[country.country_code] || "";
        return (
          <article class="py-6 sm:py-8 border-t border-(--color-line)">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-base" aria-hidden="true">{flag}</span>
              <span class="font-ui text-xs font-medium uppercase tracking-widest text-(--color-ink-muted) opacity-70">
                {country.country_name}
              </span>
            </div>
            {country.title && (
              <h3 class="font-headline text-lg sm:text-xl font-medium mb-2.5">
                {stripMd(country.title)}
              </h3>
            )}
            <div class="prose text-[0.9375rem]" set:html={md(country.summary)} />
          </article>
        );
      })}
    </div>
  </div>
</Base>
